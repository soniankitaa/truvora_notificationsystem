generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum NotificationType {
  TEAM_INVITATION
  CREATOR_REPLY
  SYSTEM
}

model Notification {
  id        String           @id @default(cuid())
  tenantId  String
  userId    String?
  type      NotificationType
  title     String
  body      String
  isRead    Boolean          @default(false)
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([tenantId])
  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}